generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
  CLIENT
}

enum ClientStatus {
  ATENDIMENTO
  PENDENTE
  CONCLUIDO
}

enum TaxRegime {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(EMPLOYEE)
  clientId  String?  // Link to specific client if Role is CLIENT
  clients   Client[] @relation("ResponsibleEmployee")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id              String       @id @default(cuid())
  name            String
  cnpj            String       @unique
  regime          TaxRegime
  status          ClientStatus @default(ATENDIMENTO)
  responsibleId   String?
  responsible     User?        @relation("ResponsibleEmployee", fields: [responsibleId], references: [id])
  lastSync        DateTime?
  tasks           Task[]
  documents       Document[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime
  completed   Boolean  @default(false)
  category    String   // Fiscal, RH, Contábil
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Document {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      String   // Nota, Guia, Contrato
  content   Bytes?
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())
}
