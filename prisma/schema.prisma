generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TipoUsuario {
  admin
  funcionario
  cliente
}

enum RegimeTributario {
  Simples_Nacional @map("Simples Nacional")
  Lucro_Presumido @map("Lucro Presumido")
  Lucro_Real @map("Lucro Real")
  MEI
}

enum PorteEmpresa {
  MEI
  ME
  EPP
  Medio @map("Médio")
  Grande
}

enum StatusContrato {
  Ativo
  Suspenso
  Cancelado
  Inadimplente
}

enum CategoriaServico {
  Contabil @map("Contábil")
  Fiscal
  RH
  Abertura_Fechamento @map("Abertura/Fechamento")
  Consultoria
  Outros
}

enum TipoObrigacao {
  Federal
  Estadual
  Municipal
}

enum Periodicidade {
  Mensal
  Trimestral
  Semestral
  Anual
  Eventual
}

enum StatusObrigacao {
  Pendente
  Em_Andamento @map("Em Andamento")
  Concluida @map("Concluída")
  Atrasada
}

enum TipoTarefa {
  Contabil @map("Contábil")
  Fiscal
  RH
  Consultoria
  Administrativo
  Outros
}

enum Prioridade {
  Baixa
  Media @map("Média")
  Alta
  Urgente
}

enum StatusTarefa {
  Pendente
  Em_Andamento @map("Em Andamento")
  Aguardando
  Concluida @map("Concluída")
  Cancelada
}

enum TipoDocumento {
  Contrato
  Certidao @map("Certidão")
  Balanco @map("Balanço")
  DRE
  Folha
  Guia
  Nota_Fiscal @map("Nota Fiscal")
  Outros
}

enum TipoAlerta {
  Vencimento
  Atraso
  Pendencia @map("Pendência")
  Sistema
  Financeiro
  Outros
}

enum NivelAlerta {
  Info
  Aviso
  Urgente
  Critico @map("Crítico")
}

enum TipoFinanceiro {
  Receita
  Despesa
}

enum StatusFinanceiro {
  Pendente
  Pago
  Atrasado
  Cancelado
}

model Usuario {
  id               Int            @id @default(autoincrement())
  nome             String         @db.VarChar(100)
  email            String         @unique @db.VarChar(100)
  senha            String         @db.VarChar(255)
  tipo_usuario     TipoUsuario    @default(cliente)
  setor_id         Int?
  foto_perfil      String?        @db.VarChar(255)
  telefone         String?        @db.VarChar(20)
  ativo            Boolean?       @default(true)
  ultimo_acesso    DateTime?
  data_criacao     DateTime?      @default(now()) @db.Timestamp(0)
  data_atualizacao DateTime?      @default(now()) @updatedAt @db.Timestamp(0)
  
  clientes         Cliente[]      @relation("UsuarioToCliente")
  clientes_resp    Cliente[]      @relation("ContadorToCliente")
  obrigacoes       ClienteObrigacao[]
  tarefas_criadas  Tarefa[]       @relation("CriadoPor")
  tarefas_resp     Tarefa[]       @relation("Responsavel")
  documentos       Documento[]
  alertas          Alerta[]
  logs             LogSistema[]

  @@index([email])
  @@index([tipo_usuario])
  @@index([ativo])
  @@map("usuarios")
}

model Setor {
  id               Int      @id @default(autoincrement())
  nome             String   @db.VarChar(100)
  descricao        String?  @db.Text
  cor              String?  @default("#0A2463") @db.VarChar(7)
  icone            String?  @default("fa-building") @db.VarChar(50)
  ativo            Boolean? @default(true)
  data_criacao     DateTime? @default(now()) @db.Timestamp(0)
  tarefas          Tarefa[]

  @@map("setores")
}

model Cliente {
  id               Int               @id @default(autoincrement())
  usuario_id       Int?
  razao_social     String            @db.VarChar(200)
  nome_fantasia    String?           @db.VarChar(200)
  cnpj             String            @unique @db.VarChar(18)
  inscricao_est    String?           @map("inscricao_estadual") @db.VarChar(20)
  inscricao_mun    String?           @map("inscricao_municipal") @db.VarChar(20)
  regime_tributario RegimeTributario
  porte_empresa    PorteEmpresa
  cnae_principal   String?           @db.VarChar(10)
  data_abertura    DateTime?         @db.Date
  
  cep              String?           @db.VarChar(9)
  logradouro       String?           @db.VarChar(200)
  numero           String?           @db.VarChar(10)
  complemento      String?           @db.VarChar(100)
  bairro           String?           @db.VarChar(100)
  cidade           String?           @db.VarChar(100)
  estado           String?           @db.VarChar(2)
  
  telefone         String?           @db.VarChar(20)
  celular          String?           @db.VarChar(20)
  email            String?           @db.VarChar(100)
  site             String?           @db.VarChar(200)
  
  responsavel_nome  String?          @db.VarChar(100)
  responsavel_cpf   String?          @db.VarChar(14)
  responsavel_email String?          @db.VarChar(100)
  responsavel_tel   String?          @map("responsavel_telefone") @db.VarChar(20)
  
  data_inicio_contr DateTime?        @map("data_inicio_contrato") @db.Date
  valor_mensalidade Decimal?          @db.Decimal(10, 2)
  dia_vencimento    Int?              @default(10)
  status_contrato   StatusContrato?   @default(Ativo)
  
  contador_resp_id  Int?              @map("contador_responsavel_id")
  
  observacoes       String?           @db.Text
  ativo             Boolean?          @default(true)
  data_criacao      DateTime?         @default(now()) @db.Timestamp(0)
  data_atualizacao  DateTime?         @default(now()) @updatedAt @db.Timestamp(0)
  
  usuario           Usuario?          @relation("UsuarioToCliente", fields: [usuario_id], references: [id])
  contador          Usuario?          @relation("ContadorToCliente", fields: [contador_resp_id], references: [id])
  servicos          ClienteServico[]
  obrigacoes        ClienteObrigacao[]
  tarefas           Tarefa[]
  documentos        Documento[]
  alertas           Alerta[]
  financeiro        Financeiro[]
  funcionarios      FuncionarioCliente[]
  certificados      CertificadoDigital[]

  @@index([cnpj])
  @@index([razao_social])
  @@index([regime_tributario])
  @@index([status_contrato])
  @@index([ativo])
  @@map("clientes")
}

model Servico {
  id               Int               @id @default(autoincrement())
  nome             String            @db.VarChar(100)
  descricao        String?           @db.Text
  categoria        CategoriaServico
  valor_base       Decimal?          @db.Decimal(10, 2)
  icone            String?           @default("fa-file") @db.VarChar(50)
  cor              String?           @default("#0A2463") @db.VarChar(7)
  ativo            Boolean?          @default(true)
  data_criacao     DateTime?         @default(now()) @db.Timestamp(0)
  clientes         ClienteServico[]

  @@map("servicos")
}

model ClienteServico {
  id               Int      @id @default(autoincrement())
  cliente_id       Int
  servico_id       Int
  valor_cobrado    Decimal? @db.Decimal(10, 2)
  data_inicio      DateTime @db.Date
  data_fim         DateTime? @db.Date
  ativo            Boolean? @default(true)
  data_criacao     DateTime? @default(now()) @db.Timestamp(0)
  
  cliente          Cliente  @relation(fields: [cliente_id], references: [id])
  servico          Servico  @relation(fields: [servico_id], references: [id])

  @@index([cliente_id])
  @@index([servico_id])
  @@map("cliente_servicos")
}

model ObrigacaoFiscal {
  id               Int               @id @default(autoincrement())
  nome             String            @db.VarChar(100)
  descricao        String?           @db.Text
  tipo             TipoObrigacao
  periodicidade    Periodicidade
  dia_vencimento   Int?
  mes_vencimento   Int?
  regime_aplicavel String?           @db.VarChar(100)
  ativo            Boolean?          @default(true)
  data_criacao     DateTime?         @default(now()) @db.Timestamp(0)
  clientes         ClienteObrigacao[]

  @@map("obrigacoes_fiscais")
}

model ClienteObrigacao {
  id               Int      @id @default(autoincrement())
  cliente_id       Int
  obrigacao_id     Int
  mes_referencia   Int
  ano_referencia   Int
  data_vencimento  DateTime @db.Date
  status           StatusObrigacao? @default(Pendente)
  responsavel_id   Int?
  data_conclusao   DateTime?
  observacoes      String?  @db.Text
  data_criacao     DateTime? @default(now()) @db.Timestamp(0)
  data_atualizacao DateTime? @default(now()) @updatedAt @db.Timestamp(0)

  cliente          Cliente  @relation(fields: [cliente_id], references: [id])
  obrigacao        ObrigacaoFiscal @relation(fields: [obrigacao_id], references: [id])
  responsavel      Usuario? @relation(fields: [responsavel_id], references: [id])

  @@index([cliente_id])
  @@index([data_vencimento])
  @@index([status])
  @@index([mes_referencia, ano_referencia])
  @@map("cliente_obrigacoes")
}

model Tarefa {
  id               Int            @id @default(autoincrement())
  titulo           String         @db.VarChar(200)
  descricao        String?        @db.Text
  cliente_id       Int?
  tipo             TipoTarefa
  prioridade       Prioridade?    @default(Media)
  status           StatusTarefa?  @default(Pendente)

  criado_por_id    Int
  responsavel_id   Int?
  setor_id         Int?

  data_inicio      DateTime?      @db.Date
  data_vencimento  DateTime?      @db.Date
  data_conclusao   DateTime?

  tempo_estimado   Int?
  tempo_gasto      Int?

  anexos           String?        @db.Text
  tags             String?        @db.VarChar(255)

  data_criacao     DateTime?      @default(now()) @db.Timestamp(0)
  data_atualizacao DateTime?      @default(now()) @updatedAt @db.Timestamp(0)

  cliente          Cliente?       @relation(fields: [cliente_id], references: [id])
  criador          Usuario        @relation("CriadoPor", fields: [criado_por_id], references: [id])
  responsavel      Usuario?       @relation("Responsavel", fields: [responsavel_id], references: [id])
  setor            Setor?         @relation(fields: [setor_id], references: [id])

  @@index([cliente_id])
  @@index([responsavel_id])
  @@index([status])
  @@index([prioridade])
  @@index([data_vencimento])
  @@map("tarefas")
}

model Documento {
  id               Int      @id @default(autoincrement())
  cliente_id       Int
  nome_arquivo     String   @db.VarChar(255)
  nome_original    String   @db.VarChar(255)
  tipo_documento   TipoDocumento
  categoria        String?  @db.VarChar(100)
  tamanho_bytes    BigInt
  extensao         String   @db.VarChar(10)
  caminho_arquivo  String   @db.VarChar(500)

  mes_referencia   Int?
  ano_referencia   Int?

  enviado_por_id   Int
  descricao        String?  @db.Text
  tags             String?  @db.VarChar(255)

  data_upload      DateTime? @default(now()) @db.Timestamp(0)

  cliente          Cliente  @relation(fields: [cliente_id], references: [id])
  enviado_por      Usuario  @relation(fields: [enviado_por_id], references: [id])

  @@index([cliente_id])
  @@index([tipo_documento])
  @@index([mes_referencia, ano_referencia])
  @@map("documentos")
}

model Alerta {
  id               Int      @id @default(autoincrement())
  tipo             TipoAlerta
  titulo           String   @db.VarChar(200)
  mensagem         String   @db.Text
  nivel            NivelAlerta? @default(Info)

  cliente_id       Int?
  usuario_id       Int?

  link_relacionado String?  @db.VarChar(500)
  lido             Boolean? @default(false)
  data_leitura     DateTime?

  data_criacao     DateTime? @default(now()) @db.Timestamp(0)

  cliente          Cliente? @relation(fields: [cliente_id], references: [id])
  usuario          Usuario? @relation(fields: [usuario_id], references: [id])

  @@index([usuario_id])
  @@index([lido])
  @@index([nivel])
  @@index([tipo])
  @@map("alertas")
}

model Financeiro {
  id               Int      @id @default(autoincrement())
  cliente_id       Int
  tipo             TipoFinanceiro @default(Receita)
  descricao        String   @db.VarChar(255)
  valor            Decimal  @db.Decimal(10, 2)

  mes_referencia   Int
  ano_referencia   Int
  data_vencimento  DateTime @db.Date
  data_pagamento   DateTime? @db.Date

  status           StatusFinanceiro? @default(Pendente)
  forma_pagamento  String?  @db.VarChar(50)

  observacoes      String?  @db.Text
  data_criacao     DateTime? @default(now()) @db.Timestamp(0)
  data_atualizacao DateTime? @default(now()) @updatedAt @db.Timestamp(0)

  cliente          Cliente  @relation(fields: [cliente_id], references: [id])

  @@index([cliente_id])
  @@index([data_vencimento])
  @@index([status])
  @@index([mes_referencia, ano_referencia])
  @@map("financeiro")
}

model LogSistema {
  id               Int      @id @default(autoincrement())
  usuario_id       Int?
  acao             String   @db.VarChar(100)
  modulo           String   @db.VarChar(50)
  descricao        String?  @db.Text
  ip_address       String?  @db.VarChar(45)
  user_agent       String?  @db.Text
  dados_anteriores String?  @db.Text
  dados_novos      String?  @db.Text
  data_criacao     DateTime? @default(now()) @db.Timestamp(0)

  usuario          Usuario? @relation(fields: [usuario_id], references: [id])

  @@index([usuario_id])
  @@index([modulo])
  @@index([data_criacao])
  @@map("logs_sistema")
}

model FuncionarioCliente {
  id               Int      @id @default(autoincrement())
  cliente_id       Int
  nome_completo    String   @db.VarChar(200)
  cpf              String   @unique @db.VarChar(14)
  rg               String?  @db.VarChar(20)
  data_nascimento  DateTime? @db.Date
  sexo             String?  // ENUM mapped manually if needed
  estado_civil     String?
  
  cep              String?  @db.VarChar(9)
  logradouro       String?  @db.VarChar(200)
  numero           String?  @db.VarChar(10)
  complemento      String?  @db.VarChar(100)
  bairro           String?  @db.VarChar(100)
  cidade           String?  @db.VarChar(100)
  estado           String?  @db.VarChar(2)
  
  telefone         String?  @db.VarChar(20)
  celular          String?  @db.VarChar(20)
  email            String?  @db.VarChar(100)
  
  cargo            String   @db.VarChar(100)
  departamento     String?  @db.VarChar(100)
  data_admissao    DateTime @db.Date
  data_demissao    DateTime? @db.Date
  tipo_contrato    String?  @default("CLT")
  
  salario_base     Decimal  @db.Decimal(10, 2)
  status           String?  @default("Ativo")
  
  ativo            Boolean? @default(true)
  data_criacao     DateTime? @default(now()) @db.Timestamp(0)
  data_atualizacao DateTime? @default(now()) @updatedAt @db.Timestamp(0)
  
  cliente          Cliente  @relation(fields: [cliente_id], references: [id])

  @@index([cliente_id])
  @@index([status])
  @@map("funcionarios_clientes")
}

model CertificadoDigital {
  id                Int      @id @default(autoincrement())
  cliente_id        Int
  tipo              String   @db.VarChar(50)
  titular           String   @db.VarChar(200)
  cpf_cnpj          String   @db.VarChar(18)
  data_emissao      DateTime @db.Date
  data_validade     DateTime @db.Date
  certificadora     String?  @db.VarChar(100)
  status            String?  @default("Ativo")
  data_criacao      DateTime? @default(now()) @db.Timestamp(0)
  data_atualizacao  DateTime? @default(now()) @updatedAt @db.Timestamp(0)
  
  cliente           Cliente  @relation(fields: [cliente_id], references: [id])

  @@index([cliente_id])
  @@index([data_validade])
  @@index([status])
  @@map("certificados_digitais")
}

model Configuracao {
  id               Int      @id @default(autoincrement())
  chave            String   @unique @db.VarChar(100)
  valor            String?  @db.Text
  tipo             String?  @default("texto") @db.VarChar(50)
  descricao        String?  @db.VarChar(255)
  data_atualizacao DateTime? @default(now()) @updatedAt @db.Timestamp(0)

  @@map("configuracoes")
}
