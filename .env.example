# DATABASE
DATABASE_URL="mysql://username:password@host:port/database"

# AUTHENTICATION
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"

# NEXTCLOUD / FILESYSTEM (Warning: Vercel storage is ephemeral)
# In production, use S3 or Google Cloud Storage for permanent documents.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SEO
# Public site URL used in canonical, sitemap and robots (e.g. https://seusite.com.br)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Google Search Console verification token (optional)
GOOGLE_SITE_VERIFICATION=""
